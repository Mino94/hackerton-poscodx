# Streamlit Cloud / 로컬 secrets.toml 예시
# 사용: 이 파일을 secrets.toml 로 복사 후 값을 채운다 (secrets.toml 은 .gitignore 됨)
# 로컬 개발만 할 때는 프로젝트 루트 .env 만 있어도 된다.

OPENAI_API_KEY = ""
OPENAI_MODEL = "gpt-4o-mini"
OPEN_SOURCE_LLM_PROVIDER = "mock"
OLLAMA_HOST = "http://127.0.0.1:11434"
OLLAMA_MODEL = "qwen2.5:7b"
AUTOPM_USE_LOCAL_LLM = "false"
AUTOPM_ENABLE_SUBAGENTS = "true"
AUTOPM_DIALOGUE_ROUNDS = "3"
AUTOPM_DIALOGUE_REVISE = "true"
AUTOPM_SUPERVISOR_CHECKPOINT = "milestones"
