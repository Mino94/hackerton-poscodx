OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# POSCO 내부 GPT (OpenAI 호환) — 비우면 https://api.openai.com/v1
OPENAI_BASE_URL=http://aigpt.posco.net/gpgpta01-gpt/v1
# Open-source / local: mock | ollama | ollama_optional | local_open_source
# Sub-Agent·피어 리뷰는 local tier(Ollama 우선)를 사용합니다.
OPEN_SOURCE_LLM_PROVIDER=mock
AUTOPM_USE_LOCAL_LLM=false
AUTOPM_ENABLE_SUBAGENTS=true
# Agent 간 다회차 대화 (기본 3라운드: 검토→응답→합의) · 대화 후 산출 보완
AUTOPM_DIALOGUE_ROUNDS=3
AUTOPM_DIALOGUE_REVISE=true
# Guided 단계 승인 속도 — 진행 시뮬레이션 생략(기본 true), 대화 라운드 1회
AUTOPM_SKIP_PROGRESS_SIM=true
AUTOPM_GUIDED_DIALOGUE_ROUNDS=1
# Supervisor 체크포인트: milestones | every | end | off
AUTOPM_SUPERVISOR_CHECKPOINT=milestones
# Core 8 파이프라인: LangGraph Orchestrator–Worker (Send) — false 시 for-loop
AUTOPM_USE_SEND_GRAPH=true
# MCP — PM Agent 도구(RAG·비용·Mermaid 등). prefetch 기본, ReAct는 OpenAI tool-calling
AUTOPM_ENABLE_MCP=true
AUTOPM_MCP_REACT=false
# RAG — Chroma + 사내 추진계획서 지식베이스(21개 가이드). OPENAI_API_KEY 있으면 임베딩
AUTOPM_USE_CHROMA_RAG=true
CHROMA_PERSIST_DIR=data/chroma_autopm
AUTOPM_RAG_COLLECTION=autopm_kb
# S01~S10 LLM 품질 파이프라인(OPENAI 필요, 느림) — 기본 false
AUTOPM_RAG_QUALITY_PIPELINE=false
# PPT 엔진 — presenton(권장) | python-pptx | both(presenton+로컬백업) | gamma(레거시 별칭)
AUTOPM_PPT_API=presenton
AUTOPM_OPENAI_ENHANCE_PPT=true
# Presenton — https://github.com/presenton/presenton
# 기동: scripts/start_presenton.ps1  또는  docker compose -f docker-compose.presenton.yml up -d
PRESENTON_BASE_URL=http://127.0.0.1:5000
PRESENTON_MCP_URL=http://127.0.0.1:5000/mcp
AUTOPM_PRESENTON_USE_MCP=true
PRESENTON_USERNAME=admin
PRESENTON_PASSWORD=changeme123
# PRESENTON_API_KEY=sk-presenton-xxxxxxxx
PRESENTON_TEMPLATE=general
PRESENTON_LANGUAGE=Korean
PRESENTON_PORT=5000
# Gamma Pro+ API Key — https://developers.gamma.app
GAMMA_API_KEY=
GAMMA_OUTPUT_LANGUAGE=ko
GAMMA_POLL_SECONDS=6
GAMMA_POLL_MAX_SECONDS=180
OLLAMA_MODEL=qwen2.5:7b
# Optional: Ollama HTTP API host (default http://127.0.0.1:11434)
# OLLAMA_HOST=http://127.0.0.1:11434
# Optional: positive integer = in-process requests/min per client_id (MVP). Leave empty for demo.
# AUTOPM_RATE_LIMIT_PER_MIN=
